{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofn.gov.cz/dcat-ap-cz-hvd/draft/série-datových-sad/schémlasdasdla.json",
  "type": "object",
  "required": [
    "@context",
    "název",
    "popis",
    "poskytovatel",
    "téma",
    "kategorie_hvd",
    "periodicita_aktualizace",
    "klíčové_slovo",
    "prvek_rúian",
    "kontaktní_bod",
    "právní_předpis"
  ],
  "properties": {
    "@context": {
      "oneOf": [
        {
          "const": "https://ofn.gov.cz/dcat-ap-cz-hvd/draft/série-datových-sad/kontext.jsonld"
        },
        {
          "type": "array",
          "contains": {
            "const": "https://ofn.gov.cz/dcat-ap-cz-hvd/draft/série-datových-sad/kontext.jsonld"
          },
          "items": {
            "type": "string",
            "format": "iri"
          }
        }
      ]
    },
    "název": {
      "title": "Text",
      "type": "object",
      "additionalProperties": {
        "title": "Hodnota v jiném jazyce",
        "type": "string"
      },
      "properties": {
        "cs": {
          "title": "Hodnota v českém jazyce",
          "type": "string"
        },
        "en": {
          "title": "Hodnota v anglickém jazyce",
          "type": "string"
        }
      }
    },
    "popis": {
      "title": "Text",
      "type": "object",
      "additionalProperties": {
        "title": "Hodnota v jiném jazyce",
        "type": "string"
      },
      "properties": {
        "cs": {
          "title": "Hodnota v českém jazyce",
          "type": "string"
        },
        "en": {
          "title": "Hodnota v anglickém jazyce",
          "type": "string"
        }
      }
    },
    "poskytovatel": {
      "type": "string",
      "format": "iri",
      "examples": [
        "https://rpp-opendata.egon.gov.cz/odrpp/zdroj/orgán-veřejné-moci/66003008"
      ]
    },
    "je_součástí": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "iri"
      }
    },
    "téma": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "iri",
        "pattern": "^http://publications\\.europa\\.eu/resource/authority/data-theme/.*$",
        "examples": [
          "http://publications.europa.eu/resource/authority/data-theme/TRAN"
        ]
      }
    },
    "kategorie_hvd": {
      "title": "kategorie HVD",
      "description": "Kategorie HVD do které série datových sad patří.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "iri",
        "pattern": "^http://data\\.europa\\.eu/bna/.*$",
        "examples": [
          "http://data.europa.eu/bna/c_1e787364",
          "http://data.europa.eu/bna/c_25f43866"
        ]
      }
    },
    "periodicita_aktualizace": {
      "type": "string",
      "format": "iri",
      "pattern": "^http://publications\\.europa\\.eu/resource/authority/frequency/.*$",
      "examples": [
        "http://publications.europa.eu/resource/authority/frequency/MONTHLY"
      ]
    },
    "klíčové_slovo": {
      "title": "Text",
      "type": "object",
      "additionalProperties": {
        "title": "Hodnota v jiném jazyce",
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "properties": {
        "cs": {
          "title": "Hodnota v českém jazyce",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "en": {
          "title": "Hodnota v anglickém jazyce",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "geografické_území": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "iri",
        "examples": [
          "http://publications.europa.eu/resource/authority/continent/EUROPE",
          "https://sws.geonames.org/6290257/"
        ]
      }
    },
    "prvek_rúian": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "iri",
        "pattern": "^https://linked.cuzk.cz/resource/ruian/.*$",
        "examples": [
          "https://linked.cuzk.cz/resource/ruian/stat/1",
          "https://linked.cuzk.cz/resource/ruian/vusc/108",
          "https://linked.cuzk.cz/resource/ruian/obec/502235"
        ]
      }
    },
    "začátek": {
      "title": "Datum",
      "type": "string",
      "format": "date"
    },
    "časové_pokrytí": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "konec": {
            "title": "Datum",
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "kontaktní_bod": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "jméno": {
              "title": "Text",
              "type": "object",
              "additionalProperties": {
                "title": "Hodnota v jiném jazyce",
                "type": "string"
              },
              "properties": {
                "cs": {
                  "title": "Hodnota v českém jazyce",
                  "type": "string"
                },
                "en": {
                  "title": "Hodnota v anglickém jazyce",
                  "type": "string"
                }
              }
            },
            "e-mail": {
              "description": "E-mailová adresa, na které lze navázat kontakt.",
              "type": "string",
              "format": "iri",
              "pattern": "^mailto:[^@]+@[^@]+",
              "examples": [
                "mailto:jan.novak@organizace.cz"
              ]
            },
            "kontaktní_stránka": {
              "title": "kontaktní stránka",
              "description": "Webová stránka, která buďto přímo umožňuje navázat kontakt, nebo obsahuje informace o tom, jak navázat kontakt.",
              "type": "string",
              "format": "iri",
              "pattern": "^https://.*$",
              "examples": [
                "https://www.mdcr.cz/Dokumenty/Verejna-doprava/Jizdni-rady,-kalendare-pro-jizdni-rady,-metodi-(1)/Jizdni-rady-verejne-dopravy"
              ]
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "jméno": {
              "title": "Text",
              "type": "object",
              "additionalProperties": {
                "title": "Hodnota v jiném jazyce",
                "type": "string"
              },
              "properties": {
                "cs": {
                  "title": "Hodnota v českém jazyce",
                  "type": "string"
                },
                "en": {
                  "title": "Hodnota v anglickém jazyce",
                  "type": "string"
                }
              }
            },
            "e-mail": {
              "description": "E-mailová adresa, na které lze navázat kontakt.",
              "type": "string",
              "format": "iri",
              "pattern": "^mailto:[^@]+@[^@]+",
              "examples": [
                "mailto:jan.novak@organizace.cz"
              ]
            },
            "kontaktní_stránka": {
              "title": "kontaktní stránka",
              "description": "Webová stránka, která buďto přímo umožňuje navázat kontakt, nebo obsahuje informace o tom, jak navázat kontakt.",
              "type": "string",
              "format": "iri",
              "pattern": "^https://.*$",
              "examples": [
                "https://www.mdcr.cz/Dokumenty/Verejna-doprava/Jizdni-rady,-kalendare-pro-jizdni-rady,-metodi-(1)/Jizdni-rady-verejne-dopravy"
              ]
            }
          }
        }
      ]
    },
    "dokumentace": {
      "type": "string",
      "format": "iri",
      "pattern": "^https://.*$",
      "examples": [
        "https://www.mdcr.cz/Dokumenty/Verejna-doprava/Jizdni-rady,-kalendare-pro-jizdni-rady,-metodi-(1)/Jizdni-rady-verejne-dopravy"
      ]
    },
    "koncept_euroVoc": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "iri",
        "pattern": "^http://eurovoc\\.europa\\.eu/.*$",
        "examples": [
          "http://eurovoc.europa.eu/1001"
        ]
      }
    },
    "právní_předpis": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "iri",
        "pattern": "^http",
        "examples": [
          "http://data.europa.eu/eli/dir/2019/1024/oj",
          "https://www.e-sbirka.cz/eli/cz/sb/1999/106/2024-01-01/dokument/norma/cast_1/par_3a/odst_6",
          "https://www.e-sbirka.cz/eli/cz/sb/1999/106/2024-01-01/dokument/norma/cast_1/par_5a/odst_1",
          "http://data.europa.eu/eli/reg_impl/2023/138/oj"
        ]
      }
    },
    "vstupní_stránka": {
      "type": "string",
      "format": "iri",
      "pattern": "^https://.*$",
      "examples": [
        "https://www.mdcr.cz/Dokumenty/Verejna-doprava/Jizdni-rady,-kalendare-pro-jizdni-rady,-metodi-(1)/Jizdni-rady-verejne-dopravy"
      ]
    }
  }
}